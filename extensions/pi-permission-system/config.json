    "ctx_search": "allow",
    "ask_user_question": "allow",
    "third_party_tool": "ask",
    "mcp": {
      "*": "ask",
      "mcp_status": "allow",
      "mcp_list": "allow",
      "mcp_search": "allow",
      "mcp_describe": "allow"
    },
    "skill": {
      "*": "ask",
      "librarian": "allow",
      "context-mode": "allow",
      "ctx-*": "allow"
    }
  }
}
